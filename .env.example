# LiteLLM Master Key (Digunakan untuk autentikasi ke Gateway)
# Ubah dengan string acak yang aman
LITELLM_MASTER_KEY=sk-master-key-rahasia

# Provider API Keys (Isi dengan API Key Anda yang valid)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL Database Settings
POSTGRES_USER=litellm_user
POSTGRES_PASSWORD=litellm_password
POSTGRES_DB=litellm_db
